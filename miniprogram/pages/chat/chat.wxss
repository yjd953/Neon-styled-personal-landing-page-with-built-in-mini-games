.container {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.messages {
  height: calc(100vh - 24rpx - 24rpx - 180rpx - env(safe-area-inset-bottom));
  overflow: hidden;
}

.messages-inner {
  padding: 20rpx 18rpx 10rpx;
}

.msg {
  display: flex;
  margin-bottom: 14rpx;
}

.msg-user {
  justify-content: flex-end;
}

.msg-assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 560rpx;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.msg-user .bubble {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.95), rgba(47, 179, 107, 0.95));
  border-color: rgba(47, 179, 107, 0.35);
}

.msg-assistant .bubble {
  background-color: rgba(255, 255, 255, 0.96);
}

.bubble-text {
  color: rgba(15, 23, 42, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
  word-break: break-all;
}

.msg-user .bubble-text {
  color: rgba(255, 255, 255, 0.96);
}

.composer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
}

.input {
  flex: 4;
  min-width: 0;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background-color: rgba(15, 23, 42, 0.04);
  color: rgba(15, 23, 42, 0.85);
}

.send-btn {
  height: 72rpx;
  flex: 1;
}

.bottom-anchor {
  height: 1rpx;
  width: 1rpx;
}
