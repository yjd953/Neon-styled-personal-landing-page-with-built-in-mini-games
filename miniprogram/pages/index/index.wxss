/**index.wxss**/

.header {
  text-align: center;
  padding-top: 20rpx;
  margin-bottom: 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 50rpx rgba(15, 23, 42, 0.16);
}

.title {
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.content {
  width: 100%;
}

.intro {
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.intro-title {
  margin-bottom: 20rpx;
  display: block;
}

.intro-text {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.65);
  margin-bottom: 15rpx;
  display: block;
}

.question-count {
  margin-bottom: 40rpx;
}

.count-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
  display: block;
}

.count-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.count-option {
  flex: 1;
  min-width: 140rpx;
  height: 80rpx;
  font-size: 28rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: rgba(15, 23, 42, 0.75);
  border-radius: 40rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-option.selected {
  background: linear-gradient(135deg, #4CAF50, #2fb36b);
  color: white;
  border-color: rgba(47, 179, 107, 0.8);
  box-shadow: 0 10rpx 24rpx rgba(76, 175, 80, 0.25);
}

.count-option::after {
  border-radius: 35rpx;
}

.start-btn {
  width: 100%;
  margin-top: 20rpx;
}

.start-btn::after {
  border-radius: 40rpx;
}
