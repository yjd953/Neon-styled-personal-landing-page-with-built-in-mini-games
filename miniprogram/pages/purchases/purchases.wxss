/* purchases.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
}

.header {
  margin-top: 6rpx;
}

.title {
}

.purchase-list {
  width: 100%;
}

.purchase-item {
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.purchase-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.product {
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(15, 23, 42, 0.85);
}

.status {
  font-size: 20rpx;
  color: rgba(47, 179, 107, 1);
  background-color: rgba(47, 179, 107, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.purchase-details {
  margin-top: 15rpx;
}

.detail {
  font-size: 20rpx;
  color: rgba(15, 23, 42, 0.65);
  margin-bottom: 10rpx;
  display: block;
}

.empty {
  margin-top: 60rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.55);
}
