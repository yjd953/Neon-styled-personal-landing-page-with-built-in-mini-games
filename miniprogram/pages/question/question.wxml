<!--question.wxml-->
<view class="page-wrap">
  <view class="max-w">
<view class="container">
  <view class="header card">
    <text class="question-number">第 {{currentQuestion + 1}} / {{questionCount}} 题</text>
    <text class="time">时间: {{formattedTime}}</text>
  </view>
  
  <view class="question-container card">
    <text class="question">{{currentQuestionData.question}}</text>
    <text class="operator">{{currentQuestionData.operator}}</text>
    <text class="question">{{currentQuestionData.number2}}</text>
    <text class="equals">=</text>
    <text class="answer">{{userAnswer}}</text>
  </view>
  
  <view class="handwriting-container card">
    <canvas
      canvas-id="handwriting"
      class="handwriting-canvas"
      style="width: 100%; height: 300rpx;"
      bindtouchstart="startDrawing"
      bindtouchmove="draw"
      bindtouchend="stopDrawing"
      bindtouchcancel="stopDrawing"
    ></canvas>
    <view class="canvas-buttons">
      <button class="btn btn-ghost clear-btn" bindtap="clearCanvas">清除</button>
      <button class="btn btn-primary submit-btn" bindtap="submitAnswer">提交答案</button>
    </view>
  </view>
  
  <view class="feedback card" wx:if="{{feedback}}">
    <text class="feedback-text" style="color: {{isCorrect ? '#4CAF50' : '#F44336'}}">{{feedback}}</text>
  </view>
  
  <view class="input-hint" wx:if="{{isDrawing}}">
    <text class="input-hint-text">正在输入答案</text>
  </view>
</view>
  </view>
</view>
