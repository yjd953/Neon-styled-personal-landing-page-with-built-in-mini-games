/* user.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  width: 100%;
  gap: 22rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.18);
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.user-id {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.6);
  display: block;
}

.member-card {
  padding: 30rpx;
  width: 100%;
}

.member-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.member-title {
}

.member-level {
  font-size: 24rpx;
  color: rgba(47, 179, 107, 1);
  font-weight: 700;
  background-color: rgba(47, 179, 107, 0.12);
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
}

.member-benefits {
  margin-top: 20rpx;
}

.benefit {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.65);
  margin-bottom: 10rpx;
  display: block;
}

.menu-list {
  padding: 10rpx 0;
  width: 100%;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.85);
}

.menu-arrow {
  width: 30rpx;
  height: 30rpx;
  transform: rotate(90deg);
}

.footer {
  margin-top: auto;
  padding: 30rpx 0;
}

.footer-text {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

.login-btn {
  margin-left: auto;
  min-width: 150rpx;
  height: 72rpx;
}
